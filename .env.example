# ============================================================
# Geo Collab 环境变量配置模板
# 复制为 .env 后填入真实值，docker-compose 和 app 共用此文件
# ============================================================

# ---------- MySQL 数据库 ----------
# MySQL root 密码（必填）
MYSQL_ROOT_PASSWORD=change_me_root

# MySQL 数据库名（默认 geo_collab）
MYSQL_DATABASE=geo_collab

# MySQL 应用用户（默认 geo_user）
MYSQL_USER=geo_user

# MySQL 应用用户密码（必填）
MYSQL_PASSWORD=change_me_user

# ---------- 应用数据库连接 ----------
# FastAPI 连接 MySQL 的 URL（docker-compose 自动拼接，无需手动设）
# GEO_DATABASE_URL=mysql+pymysql://geo_user:change_me_user@mysql:3306/geo_collab

# ---------- JWT 鉴权 ----------
# JWT 签名密钥（必填，用 openssl rand -hex 32 生成）
GEO_JWT_SECRET=change_me_jwt_secret_64_chars_minimum

# ---------- 初始用户 ----------
# 系统初始化时的种子用户，JSON 数组格式
# 示例: [{"username":"admin","password":"admin123"}]
GEO_SEED_USERS=change_me_json_array

# ---------- 本地 API Token ----------
# 本地 API 鉴权 token（可选，留空则自动生成）
# GEO_LOCAL_API_TOKEN=

# ---------- 数据目录 ----------
# 应用持久化数据目录（Docker 内使用 /app/data）
GEO_DATA_DIR=/app/data

# ---------- 远程浏览器（发布时需要）----------
# 启用远程 XVFB + noVNC 模式（Docker 环境必须设为 true）
GEO_PUBLISH_REMOTE_BROWSER_ENABLED=true

# Xvfb 可执行文件路径
GEO_PUBLISH_XVFB_PATH=Xvfb

# x11vnc 可执行文件路径
GEO_PUBLISH_X11VNC_PATH=x11vnc

# websockify 可执行文件路径
GEO_PUBLISH_WEBSOCKIFY_PATH=websockify

# noVNC 静态文件目录（Debian 包默认路径）
GEO_PUBLISH_NOVNC_WEB_DIR=/usr/share/novnc

# VNC 对外监听地址（0.0.0.0 允许外部访问）
GEO_PUBLISH_REMOTE_BROWSER_HOST=0.0.0.0

# ---------- 远程浏览器高级配置（可选）----------
# X display 起始编号（默认 99）
# GEO_PUBLISH_REMOTE_BROWSER_DISPLAY_BASE=99

# VNC 端口起始值（默认 5900）
# GEO_PUBLISH_REMOTE_BROWSER_VNC_BASE_PORT=5900

# noVNC 端口起始值（默认 6080）
# GEO_PUBLISH_REMOTE_BROWSER_NOVNC_BASE_PORT=6080

# Xvfb/VNC/noVNC 启动超时秒数（默认 15）
# GEO_PUBLISH_REMOTE_BROWSER_START_TIMEOUT=15

# 浏览器空闲超时秒数（默认 300，无操作后自动清理）
# GEO_PUBLISH_REMOTE_BROWSER_IDLE_TIMEOUT=300

# ---------- 发布引擎 ----------
# 最大并发发布记录数（默认 5，上限 5）
# GEO_PUBLISH_MAX_CONCURRENT_RECORDS=5

# 单条发布记录超时秒数（默认 300）
# GEO_PUBLISH_RECORD_TIMEOUT_SECONDS=300

# 浏览器渠道（默认 chrome，Docker 内可用 chromium）
# GEO_PUBLISH_BROWSER_CHANNEL=chromium

# 浏览器可执行文件路径（可选，Chromium 通常自动发现）
# GEO_PUBLISH_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
